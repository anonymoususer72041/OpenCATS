<div id="careerContent">
        <registeredCandidate>
        <h1>Position Details: <title></h1>
        <table id="detailsTable">
            <tr>
                <td class="detailsHeader"><strong>Location:</strong></td>
                <td><city>, <state></td>
			</tr>
			<tr>
                <td class="detailsHeader"><strong>Openings:</strong></td>
                <td><openings></td>
			</tr>
            <tr>
                <td class="detailsHeader"><strong>Salary Range:</strong></td>
                <td><salary></td>
            </tr>
        </table>
        <div id="descriptive">
            <p><strong>Description:</strong></p>
            <description>
		</div>
        <div id="detailsTools">
        	<h2>Perform an action:</h2>
        	<a-applyToJob onmouseover="buttonMouseOver('applyToPosition',true);" onmouseout="buttonMouseOver('applyToPosition',false);"><img src="images/careers_apply.gif" id="applyToPosition" alt="IMAGE: Apply to Position" /></a>
        </div>
    </div>
