<div id="careerContent">
    <h1><applyContent>Applying to <title></applyContent></h1>
    <center>
    <table cellpadding="0" cellspacing="0">
        <tr>
            <td><label id="emailLabel" for="email"><h2>Enter your e-mail address:</h2></label></td>
            <td><input-email></td>
        </tr>
        <tr>
            <td align="right" valign="top"><input-new></td>
            <td style="line-height: 18px;">
                <applyContent>
                <strong>I have not registered on this website.</strong><br />
                (I haven't applied to any jobs online)
                </applyContent>
            </td>
        </tr>
        <tr>
            <td align="right" valign="top"><input-registered></td>
            <td style="line-height: 20px;">
                <strong>I have registered before</strong><br />
                and my last name is:<br />
                <input-lastName><br />
                and my zip code is:<br />
                <input-zip><br /><br />
                <input-rememberMe> Remember my information for future visits<br /><br />
                <input-submit><br /><br />
            </td>
        </tr>
    </table>
    </center>
</div>
